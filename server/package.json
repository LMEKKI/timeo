{
	"name": "server",
	"version": "0.0.1",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./client": {
			"types": "./dist/client.d.ts",
			"default": "./dist/client.js"
		}
	},
	"scripts": {
		"build": "bun --env-file=../.env.local x tsc",
		"dev": "bun --env-file=../.env.local --watch run src/index.ts",
		"test": "bun test",
		"type-check": "bun --env-file=../.env.local x tsc --noEmit",
		"lint": "biome lint src/",
		"db:generate": "bun --env-file=../.env.local x drizzle-kit generate",
		"db:push": "bun --env-file=../.env.local x drizzle-kit push",
		"db:seed": "bun --env-file=../.env.local run src/db/seed.ts"
	},
	"dependencies": {
		"@better-auth/drizzle-adapter": "^1.6.19",
		"hono": "^4.10.8",
		"better-auth": "^1.6.19",
		"drizzle-orm": "^0.45.2",
		"postgres": "^3.4.9",
		"shared": "workspace:*",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"drizzle-kit": "^0.31.10"
	}
}
