# ──────────────────────────────────────────────
# Timeo — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env.local and fill values.

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/timeo

# Better Auth
BETTER_AUTH_SECRET=change-me-32-chars-minimum
BETTER_AUTH_URL=http://localhost:3000

# Geocoding (Photon / OpenStreetMap - no API key needed)
# Free, open-source, no signup. Just leave the next line commented.

# CORS
CORS_ORIGIN=http://localhost:5173

# Server
PORT=3000
NODE_ENV=development

# Client (Vite)
VITE_API_URL=http://localhost:3000
