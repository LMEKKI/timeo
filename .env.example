# ──────────────────────────────────────────────
# Timeo — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env.local and fill values.

# Database
# - Local: postgresql://user:pass@localhost:5432/timeo
# - Supabase prod: use the Transaction-mode pooler URL (port 6543)
DATABASE_URL=postgresql://postgres:password@localhost:5432/timeo

# Better Auth
# - Generate with: openssl rand -base64 32 (32+ chars required)
# - Prod: must be a unique secret, never reuse the dev value
BETTER_AUTH_SECRET=change-me-32-chars-minimum
BETTER_AUTH_URL=http://localhost:3000

# Google Maps (Geocoding)
# - Restrict the key to your Vercel domain in production
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# CORS
# - Must match the client URL exactly (no trailing slash)
CORS_ORIGIN=http://localhost:5173

# Server
PORT=3000
NODE_ENV=development

# Client (Vite — exposed to browser at build time)
# - Prod: https://your-app.vercel.app
VITE_API_URL=http://localhost:3000
