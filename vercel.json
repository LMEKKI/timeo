{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"buildCommand": "bun run build",
	"installCommand": "bun install --frozen-lockfile",
	"framework": null,
	"outputDirectory": "client/dist",
	"rewrites": [
		{ "source": "/((?!api/).*)", "destination": "/index.html" }
	],
	"functions": {
		"api/index.ts": {
			"runtime": "nodejs20.x",
			"maxDuration": 10
		}
	}
}
