# ──────────────────────────────────────────────
# Timeo — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env.local and fill values.

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/timeo

# Authentication
AUTH_SECRET=change-me-to-a-random-64-char-string

# File Storage
STORAGE_PROVIDER=s3
S3_BUCKET=timeo-uploads
S3_REGION=eu-west-3
S3_ACCESS_KEY=
S3_SECRET_KEY=

# App
PORT=3000
NODE_ENV=development
